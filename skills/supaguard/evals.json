{
  "skill": "supaguard",
  "version": "0.1.0",
  "evals": [
    {
      "id": "eval-001",
      "description": "Triggers on monitoring setup request",
      "prompt": "Set up monitoring for my Next.js app",
      "type": "workflow",
      "assertions": [
        { "type": "contains", "value": "supaguard" },
        { "type": "contains", "value": "whoami" },
        { "type": "contains", "value": "page.goto" }
      ]
    },
    {
      "id": "eval-002",
      "description": "Triggers on uptime check request",
      "prompt": "I want to monitor if my login page is working in production",
      "type": "workflow",
      "assertions": [
        { "type": "contains", "value": "supaguard" },
        { "type": "contains", "value": "@playwright/test" },
        { "type": "contains", "value": "/tmp/sg-check" }
      ]
    },
    {
      "id": "eval-003",
      "description": "Triggers on supaguard CLI mention",
      "prompt": "How do I deploy a check with supaguard?",
      "type": "explanation",
      "assertions": [
        { "type": "contains", "value": "checks create" },
        { "type": "contains", "value": "--locations" },
        { "type": "contains", "value": "--cron" }
      ]
    },
    {
      "id": "eval-004",
      "description": "Generates valid Playwright script with correct imports",
      "prompt": "Create a monitoring check for my homepage at https://example.com",
      "type": "code_generation",
      "assertions": [
        { "type": "contains", "value": "import { test, expect } from \"@playwright/test\"" },
        { "type": "contains", "value": "page.goto" },
        { "type": "contains", "value": "https://example.com" },
        { "type": "not_contains", "value": "console.log" }
      ]
    },
    {
      "id": "eval-005",
      "description": "Writes script to tmp directory, not project",
      "prompt": "Monitor my checkout flow",
      "type": "workflow",
      "assertions": [
        { "type": "contains", "value": "/tmp/sg-check" },
        { "type": "not_contains", "value": "src/" },
        { "type": "not_contains", "value": "tests/" }
      ]
    },
    {
      "id": "eval-006",
      "description": "Uses --json flag for CLI commands",
      "prompt": "Test my monitoring script at /tmp/sg-check-abc.ts",
      "type": "workflow",
      "assertions": [
        { "type": "contains", "value": "--json" },
        { "type": "contains", "value": "supaguard checks test" }
      ]
    },
    {
      "id": "eval-007",
      "description": "Does not use React Testing Library APIs",
      "prompt": "Create a check that verifies the search form works on https://example.com/search",
      "type": "code_generation",
      "assertions": [
        { "type": "not_contains", "value": "getByDisplayValue" },
        { "type": "not_contains", "value": "queryByText" },
        { "type": "not_contains", "value": "findByRole" },
        { "type": "contains", "value": "page.getBy" }
      ]
    },
    {
      "id": "eval-008",
      "description": "Does not use waitForTimeout",
      "prompt": "Generate a monitoring script for a slow-loading dashboard",
      "type": "code_generation",
      "assertions": [
        { "type": "not_contains", "value": "waitForTimeout" },
        { "type": "not_contains", "value": "sleep" },
        { "type": "contains", "value": "toBeVisible" }
      ]
    },
    {
      "id": "eval-009",
      "description": "Does not import forbidden modules",
      "prompt": "Create a check that reads a config file and monitors the URL from it",
      "type": "code_generation",
      "assertions": [
        { "type": "not_contains", "value": "require('fs')" },
        { "type": "not_contains", "value": "from 'fs'" },
        { "type": "not_contains", "value": "child_process" }
      ]
    },
    {
      "id": "eval-010",
      "description": "Asks about deployment interactively, does not auto-deploy",
      "prompt": "My check test passed. What now?",
      "type": "explanation",
      "assertions": [
        { "type": "contains", "value": "name" },
        { "type": "contains", "value": "schedule" },
        { "type": "contains", "value": "region" }
      ]
    },
    {
      "id": "eval-011",
      "description": "Handles on-demand checks correctly with pause",
      "prompt": "Deploy my check as on-demand only, no recurring schedule",
      "type": "workflow",
      "assertions": [
        { "type": "contains", "value": "0 0 1 1 *" },
        { "type": "contains", "value": "pause" }
      ]
    },
    {
      "id": "eval-012",
      "description": "References correct available regions",
      "prompt": "What regions can I deploy my monitoring check to?",
      "type": "explanation",
      "assertions": [
        { "type": "contains", "value": "eastus" },
        { "type": "contains", "value": "northeurope" },
        { "type": "contains", "value": "centralindia" }
      ]
    },
    {
      "id": "eval-013",
      "description": "Loads references when CLI details are needed",
      "prompt": "Show me all the supaguard CLI commands for managing checks",
      "type": "explanation",
      "assertions": [
        { "type": "loads_reference", "value": "references/cli-reference.md" }
      ]
    }
  ]
}
