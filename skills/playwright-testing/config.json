{
  "$schema": "https://absolutelyskilled.dev/schemas/skill-config.json",
  "_comment": "Project-specific Playwright settings. The agent reads this on activation to avoid repeat questions. Edit values to match your project.",
  "baseURL": "http://localhost:3000",
  "testDir": "./tests",
  "authStrategy": "storageState",
  "authStoragePath": ".auth/",
  "ciProvider": "github-actions",
  "browsers": ["chromium"],
  "screenshotBaseline": "linux",
  "dockerImage": "mcr.microsoft.com/playwright:v1.48.0-noble",
  "shardCount": 4,
  "customFixturesPath": "./tests/fixtures.ts"
}
