{
  "name": "absolutelyskilled-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "tsx scripts/generate-og-images.ts",
    "build": "astro build",
    "postbuild": "if [ -d .vercel/output/static ]; then npx pagefind --site .vercel/output/static; else npx pagefind --site dist; fi",
    "preview": "astro preview",
    "generate:readmes": "tsx scripts/generate-readmes.ts",
    "generate:llms": "tsx scripts/generate-llms-txt.ts",
    "generate:og": "tsx scripts/generate-og-images.ts",
    "generate:all": "tsx scripts/generate-readmes.ts && tsx scripts/generate-llms-txt.ts && tsx scripts/generate-og-images.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/vercel": "^10.0.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.0.7",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "satori": "^0.26.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "24.14.0"
  }
}
