---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SkillCard from '../../components/SkillCard.astro';
import { getAllSkills, getSkillsByCategory } from '../../lib/skills';
import { getCategoryMeta, CATEGORIES } from '../../lib/categories';
import { getCategoryPageSEO } from '../../lib/seo';

export async function getStaticPaths() {
  const skills = getAllSkills();
  const grouped = getSkillsByCategory(skills);

  return Object.entries(grouped).map(([category, skills]) => ({
    params: { category },
    props: { skills, category },
  }));
}

const { skills, category } = Astro.props;
const meta = getCategoryMeta(category);
const skillItems = skills.map((s) => ({ name: s.name, slug: s.slug }));
const seo = getCategoryPageSEO(category, meta.label, skills.length, skillItems);

// Get related categories (other categories with skills)
const allSkills = getAllSkills();
const grouped = getSkillsByCategory(allSkills);
const relatedCategories = Object.entries(grouped)
  .filter(([cat]) => cat !== category)
  .sort(([, a], [, b]) => b.length - a.length)
  .slice(0, 6)
  .map(([cat, catSkills]) => ({
    ...getCategoryMeta(cat),
    count: catSkills.length,
  }));
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  jsonLd={seo.jsonLd}
  additionalJsonLd={seo.additionalJsonLd}
  breadcrumbs={seo.breadcrumbs}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <a href="/skills" class="text-sm text-text-muted hover:text-text-secondary transition-colors mb-4 inline-block">
        &larr; All skills
      </a>
      <h1 class="text-3xl font-bold font-mono" style={`color: ${meta.color};`}>
        {meta.label}
      </h1>
      <p class="text-text-secondary mt-2">{skills.length} skills in this category</p>
      {meta.description && (
        <p class="text-text-secondary mt-3 max-w-2xl text-sm leading-relaxed">{meta.description}</p>
      )}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {skills.map((skill) => (
        <SkillCard
          slug={skill.slug}
          name={skill.name}
          description={skill.description}
          category={skill.category}
          tags={skill.tags}
        />
      ))}
    </div>

    <!-- Related categories for internal linking -->
    {relatedCategories.length > 0 && (
      <section class="mt-16 pt-8 border-t border-border">
        <h2 class="text-lg font-semibold font-mono text-text-primary mb-4">Explore Other Categories</h2>
        <div class="flex flex-wrap gap-2">
          {relatedCategories.map((cat) => (
            <a
              href={`/category/${cat.slug}`}
              class="px-3 py-1.5 rounded-full text-xs font-medium border border-border text-text-secondary hover:border-border-hover transition-colors"
            >
              {cat.label} ({cat.count})
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
