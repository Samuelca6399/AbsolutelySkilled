---
import SkillLayout from '../../layouts/SkillLayout.astro';
import TabSwitcher from '../../components/TabSwitcher.astro';
import { getAllSkills, getSkillsByCategory } from '../../lib/skills';
import { getInstallCount } from '../../lib/installs';
import { getSkillPageSEO } from '../../lib/seo';
import { renderMarkdown } from '../../lib/markdown';

export async function getStaticPaths() {
  const skills = getAllSkills();
  const grouped = getSkillsByCategory(skills);
  return skills.map((skill) => {
    const categorySkills = grouped[skill.category] || [];
    const sortedCategory = categorySkills.sort((a, b) => a.name.localeCompare(b.name));
    const idx = sortedCategory.findIndex((s) => s.slug === skill.slug);
    const prev = idx > 0 ? sortedCategory[idx - 1] : null;
    const next = idx < sortedCategory.length - 1 ? sortedCategory[idx + 1] : null;
    const moreInCategory = sortedCategory
      .filter((s) => s.slug !== skill.slug)
      .slice(0, 5);
    return {
      params: { slug: skill.slug },
      props: { skill, prev, next, moreInCategory },
    };
  });
}

const { skill, prev, next, moreInCategory } = Astro.props;
const installCount = getInstallCount(skill.slug);
const seo = getSkillPageSEO(skill, installCount);

// Strip the companion check footer from the body for display
const bodyContent = skill.body
  .replace(/---\s*\n## Companion check[\s\S]*$/, '')
  .trim();

// Strip activation emoji line
const cleanBody = bodyContent.replace(/^When this skill is activated.*\n\n?/m, '');
const cleanReadme = skill.readme?.replace(/^When this skill is activated.*\n\n?/m, '') || null;

const overviewHtml = renderMarkdown(cleanReadme || cleanBody);
const bodyHtml = renderMarkdown(cleanBody);
const refsHtml = skill.references.map((ref) => ({
  filename: ref.filename,
  html: renderMarkdown(ref.content),
}));
---

<SkillLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  image={seo.image}
  jsonLd={seo.jsonLd}
  additionalJsonLd={seo.additionalJsonLd}
  breadcrumbs={seo.breadcrumbs}
  skill={skill}
  installCount={installCount}
>
  <div data-pagefind-body>
    <h1
      class="text-3xl font-bold font-mono mb-2"
      data-pagefind-meta="title"
    >
      {skill.name}
    </h1>
    <p class="text-text-secondary mb-6">{skill.description}</p>
    <span data-pagefind-filter="category" class="hidden">{skill.category}</span>
    {skill.tags.map((tag) => (
      <span data-pagefind-filter="tag" class="hidden">{tag}</span>
    ))}

    <!-- Definition block for AEO / featured snippets -->
    <section class="card p-5 mb-6 border-l-4 border-l-accent-blue">
      <h2 class="text-lg font-semibold font-mono mb-2 text-text-primary">What is {skill.name}?</h2>
      <p class="text-text-secondary text-sm leading-relaxed">{skill.description}</p>
    </section>

    <TabSwitcher>
      <div slot="overview" class="prose-dark">
        <Fragment set:html={overviewHtml} />
      </div>

      <div slot="files" class="space-y-8">
        <div>
          <h2 class="text-xl font-semibold font-mono mb-4 text-text-primary">SKILL.md</h2>
          <div class="prose-dark">
            <Fragment set:html={bodyHtml} />
          </div>
        </div>

        {refsHtml.length > 0 && (
          <div class="space-y-8">
            <h2 class="text-xl font-semibold font-mono text-text-primary">References</h2>
            {refsHtml.map((ref) => (
              <div class="card p-6">
                <h3 class="text-lg font-mono font-semibold text-text-primary mb-4">
                  {ref.filename}
                </h3>
                <div class="prose-dark">
                  <Fragment set:html={ref.html} />
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </TabSwitcher>

    <!-- FAQ section matching FAQPage schema -->
    <section class="mt-10 space-y-4">
      <h2 class="text-xl font-semibold font-mono text-text-primary">Frequently Asked Questions</h2>
      {seo.faqEntries.map((faq) => (
        <div class="card p-5">
          <h3 class="font-semibold text-text-primary mb-2">{faq.q}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </section>

    <!-- Prev / Next navigation within category -->
    {(prev || next) && (
      <nav class="mt-10 flex items-stretch gap-4" aria-label="Adjacent skills">
        {prev ? (
          <a href={`/skill/${prev.slug}`} class="card p-4 flex-1 group hover:border-border-hover transition-colors">
            <span class="text-xs text-text-muted">Previous</span>
            <span class="block font-mono text-sm text-text-primary group-hover:text-accent-blue transition-colors mt-1">{prev.name}</span>
          </a>
        ) : <div class="flex-1" />}
        {next ? (
          <a href={`/skill/${next.slug}`} class="card p-4 flex-1 text-right group hover:border-border-hover transition-colors">
            <span class="text-xs text-text-muted">Next</span>
            <span class="block font-mono text-sm text-text-primary group-hover:text-accent-blue transition-colors mt-1">{next.name}</span>
          </a>
        ) : <div class="flex-1" />}
      </nav>
    )}
  </div>
</SkillLayout>
