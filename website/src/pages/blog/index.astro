---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { getBlogIndexSEO } from '../../lib/seo';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const seo = getBlogIndexSEO();
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  additionalJsonLd={seo.additionalJsonLd}
  breadcrumbs={seo.breadcrumbs}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold font-mono mb-8">Blog</h1>

    {posts.length === 0 ? (
      <p class="text-text-secondary">No posts yet. Check back soon!</p>
    ) : (
      <div class="grid gap-6">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            date={post.data.date}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
