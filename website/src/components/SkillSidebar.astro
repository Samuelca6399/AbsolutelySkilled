---
import CategoryBadge from './CategoryBadge.astro';
import TagPill from './TagPill.astro';
import InstallCommand from './InstallCommand.astro';
import RecommendedSkills from './RecommendedSkills.astro';
import type { Skill } from '../lib/skills';

interface Props {
  skill: Skill;
  installCount: number;
}

const { skill, installCount } = Astro.props;
---

<div class="space-y-6">
  <div class="card p-5">
    <h3 class="font-semibold text-text-primary mb-4 text-sm uppercase tracking-wider">Install</h3>
    <InstallCommand slug={skill.slug} />
  </div>

  <div class="card p-5 space-y-4">
    <div>
      <h4 class="text-xs text-text-muted uppercase tracking-wider mb-2">Category</h4>
      <CategoryBadge category={skill.category} />
    </div>

    <div>
      <h4 class="text-xs text-text-muted uppercase tracking-wider mb-2">Version</h4>
      <span class="font-mono text-sm text-text-secondary">{skill.version}</span>
    </div>

    {installCount > 0 && (
      <div>
        <h4 class="text-xs text-text-muted uppercase tracking-wider mb-2">Installs</h4>
        <span class="font-mono text-sm text-text-secondary">{installCount.toLocaleString()}</span>
      </div>
    )}

    <div>
      <h4 class="text-xs text-text-muted uppercase tracking-wider mb-2">Platforms</h4>
      <div class="flex flex-wrap gap-1">
        {skill.platforms.map((p) => (
          <span class="inline-block px-2 py-0.5 rounded text-xs font-mono text-text-secondary bg-elevated border border-border">
            {p}
          </span>
        ))}
      </div>
    </div>

    {skill.tags.length > 0 && (
      <div>
        <h4 class="text-xs text-text-muted uppercase tracking-wider mb-2">Tags</h4>
        <div class="flex flex-wrap gap-1">
          {skill.tags.map((tag) => (
            <TagPill tag={tag} />
          ))}
        </div>
      </div>
    )}

    {skill.maintainers.length > 0 && (
      <div>
        <h4 class="text-xs text-text-muted uppercase tracking-wider mb-2">Maintainers</h4>
        <div class="space-y-1">
          {skill.maintainers.map((m) => (
            <a
              href={`https://github.com/${m.github}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-text-secondary hover:text-accent-blue transition-colors"
            >
              <img
                src={`https://github.com/${m.github}.png?size=24`}
                alt={m.github}
                class="w-5 h-5 rounded-full"
                loading="lazy"
              />
              @{m.github}
            </a>
          ))}
        </div>
      </div>
    )}

    <div>
      <h4 class="text-xs text-text-muted uppercase tracking-wider mb-2">License</h4>
      <span class="text-sm text-text-secondary">{skill.license}</span>
    </div>
  </div>

  {skill.recommended_skills.length > 0 && (
    <RecommendedSkills skills={skill.recommended_skills} />
  )}
</div>
