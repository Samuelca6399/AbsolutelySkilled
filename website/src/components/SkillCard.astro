---
import CategoryBadge from './CategoryBadge.astro';
import { getInstallCount } from '../lib/installs';
import { getCategoryMeta } from '../lib/categories';

interface Props {
  slug: string;
  name: string;
  description: string;
  category: string;
  tags?: string[];
}

const { slug, name, description, category, tags = [] } = Astro.props;
const installs = getInstallCount(slug);
const categoryMeta = getCategoryMeta(category);
---

<a href={`/skill/${slug}`} class="card p-5 block group" data-pagefind-ignore>
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-mono font-semibold text-text-primary group-hover:text-accent-blue transition-colors">
      {name}
    </h3>
    {installs > 0 && (
      <span class="text-xs text-text-muted font-mono shrink-0 ml-2">{installs.toLocaleString()} installs</span>
    )}
  </div>
  <p class="text-sm text-text-secondary mb-3 line-clamp-2">{description}</p>
  <div class="flex items-center gap-2 flex-wrap">
    <CategoryBadge category={category} linked={false} />
    {tags.slice(0, 3).map((tag) => (
      <span class="text-xs text-text-muted font-mono">#{tag}</span>
    ))}
  </div>
</a>
