---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
const command = `npx skills add AbsolutelySkilled/AbsolutelySkilled --skill ${slug}`;
---

<div class="install-block group relative">
  <code class="flex-1 text-text-primary truncate">{command}</code>
  <button
    class="copy-btn shrink-0 px-2 py-1 rounded text-xs font-mono transition-colors bg-border hover:bg-border-hover text-text-secondary hover:text-text-primary cursor-pointer"
    data-copy={command}
  >
    Copy
  </button>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      await navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });
</script>
