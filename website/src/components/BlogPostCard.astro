---
interface Props {
  title: string;
  description: string;
  slug: string;
  date: string;
  tags?: string[];
}

const { title, description, slug, date, tags = [] } = Astro.props;
---

<a href={`/blog/${slug}`} class="card p-5 block group">
  <time datetime={date} class="text-xs text-text-muted font-mono">
    {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
  </time>
  <h3 class="font-semibold text-text-primary mt-2 mb-2 group-hover:text-accent-blue transition-colors">
    {title}
  </h3>
  <p class="text-sm text-text-secondary line-clamp-2">{description}</p>
  {tags.length > 0 && (
    <div class="flex gap-2 mt-3">
      {tags.slice(0, 3).map((tag) => (
        <span class="text-xs text-text-muted font-mono">#{tag}</span>
      ))}
    </div>
  )}
</a>
