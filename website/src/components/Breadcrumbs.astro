---
import type { BreadcrumbItem } from '../lib/seo';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <ol class="flex items-center gap-1.5 text-sm text-text-muted">
      {items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && <span class="text-border">/</span>}
          {i < items.length - 1 ? (
            <a href={item.url} class="hover:text-text-secondary transition-colors">
              {item.name}
            </a>
          ) : (
            <span class="text-text-secondary" aria-current="page">
              {item.name}
            </span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}
