---
interface Props {
  tab1Label?: string;
  tab2Label?: string;
}

const { tab1Label = 'Overview', tab2Label = 'Files' } = Astro.props;
---

<div class="tab-switcher">
  <input type="radio" name="skill-tab" id="tab-overview" class="sr-only peer/overview" checked />
  <input type="radio" name="skill-tab" id="tab-files" class="sr-only peer/files" />

  <div class="flex border-b border-border mb-6">
    <label
      for="tab-overview"
      class="tab-label px-4 py-2 text-sm font-medium cursor-pointer border-b-2 border-transparent text-text-secondary hover:text-text-primary transition-colors peer-checked/overview:border-accent-blue peer-checked/overview:text-text-primary"
    >
      {tab1Label}
    </label>
    <label
      for="tab-files"
      class="tab-label px-4 py-2 text-sm font-medium cursor-pointer border-b-2 border-transparent text-text-secondary hover:text-text-primary transition-colors peer-checked/files:border-accent-blue peer-checked/files:text-text-primary"
    >
      {tab2Label}
    </label>
  </div>

  <div class="hidden peer-checked/overview:block">
    <slot name="overview" />
  </div>

  <div class="hidden peer-checked/files:block">
    <slot name="files" />
  </div>
</div>
