---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { BreadcrumbItem } from '../lib/seo';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
  additionalJsonLd?: Record<string, unknown>[];
  breadcrumbs?: BreadcrumbItem[];
}

const { title, description, canonical, image, jsonLd, additionalJsonLd, breadcrumbs } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <SEOHead title={title} description={description} canonical={canonical} image={image} jsonLd={jsonLd} additionalJsonLd={additionalJsonLd} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    {breadcrumbs && breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      document.querySelectorAll('.prose-dark pre').forEach((pre) => {
        const btn = document.createElement('button');
        btn.className = 'code-copy-btn';
        btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code');
          const text = code ? code.innerText : pre.innerText;
          await navigator.clipboard.writeText(text);
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        });
        pre.appendChild(btn);
      });

      // Fetch fresh install counts from GitHub and update DOM
      (async () => {
        try {
          const res = await fetch(
            'https://raw.githubusercontent.com/AbsolutelySkilled/AbsolutelySkilled/main/data/installs.json',
            { cache: 'no-cache' }
          );
          if (!res.ok) return;
          const data = await res.json();

          // Update per-skill install counts
          document.querySelectorAll<HTMLElement>('[data-installs-slug]').forEach((el) => {
            const slug = el.dataset.installsSlug!;
            const count = data[slug];
            if (count && count > 0) {
              el.textContent = count.toLocaleString();
              el.closest('[data-installs-wrapper]')?.classList.remove('hidden');
            }
          });

          // Update total installs
          document.querySelectorAll<HTMLElement>('[data-installs-total]').forEach((el) => {
            if (data._total) el.textContent = data._total.toLocaleString();
          });

          // Update data-installs attribute for sorting on /skills page
          document.querySelectorAll<HTMLElement>('[data-installs]').forEach((el) => {
            const name = el.dataset.name;
            if (name) {
              const slug = Object.keys(data).find((k) => k === name);
              if (slug && data[slug]) {
                el.dataset.installs = String(data[slug]);
              }
            }
          });
        } catch {
          // Silently fail - build-time data is the fallback
        }
      })();
    </script>
  </body>
</html>
