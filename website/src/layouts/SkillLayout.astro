---
import BaseLayout from './BaseLayout.astro';
import SkillSidebar from '../components/SkillSidebar.astro';
import type { Skill } from '../lib/skills';
import type { BreadcrumbItem } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
  additionalJsonLd?: Record<string, unknown>[];
  breadcrumbs?: BreadcrumbItem[];
  skill: Skill;
  installCount: number;
}

const { title, description, canonical, image, jsonLd, additionalJsonLd, breadcrumbs, skill, installCount } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} image={image} jsonLd={jsonLd} additionalJsonLd={additionalJsonLd} breadcrumbs={breadcrumbs}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="lg:grid lg:grid-cols-[1fr_300px] lg:gap-8">
      <div class="min-w-0">
        <slot />
      </div>
      <aside class="hidden lg:block">
        <div class="sticky top-8">
          <SkillSidebar skill={skill} installCount={installCount} />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
